    "find-skills": "off",
    "hello-skill": "off",
    "nippo": "off",
    "officecli": "off"
  },
  "statusLine": {
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd'); model=$(echo \"$input\" | jq -r '.model.display_name'); branch=$(git -C \"$current_dir\" branch --show-current 2>/dev/null || echo 'no-git'); printf '\\033[2m%s@%s \\033[36m%s\\033[0m \\033[33m[%s]\\033[0m \\033[2m%s\\033[0m' \"$(whoami)\" \"$(hostname -s)\" \"$(basename \"$current_dir\")\" \"$branch\" \"$(date +%H:%M)\"",
    "type": "command"
  },
  "tui": "fullscreen"
